# Distributed deployment
APP_NAME=Infrared Vision Gateway
APP_VERSION=0.2.0
APP_RELEASE_CHANNEL=distributed

# Authentication
AUTH_SECRET=change-me-in-production
AUTH_EXPIRES_MINUTES=30
AUTH_REFRESH_EXPIRES_DAYS=7
IAM_MODE=external
IAM_SERVICE_URL=http://infrared_iam:8020
IAM_RELEASE_CHANNEL=iam

# CV service
CV_SERVICE_MODE=remote
CV_SERVICE_URL=http://infrared_cv_service:8030
CV_SERVICE_TIMEOUT=10.0
CV_RELEASE_CHANNEL=cv

# Queue
QUEUE_BACKEND=redis
QUEUE_URL=redis://redis:6379/0
QUEUE_NAME=infrared:inference:queue
QUEUE_RESULT_TTL_SECONDS=3600
WORKER_RELEASE_CHANNEL=worker

# Vector search
VECTOR_DB_BACKEND=memory
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=infrared_vision_knowledge
QDRANT_TIMEOUT=3.0

# Database
DB_BACKEND=postgresql
POSTGRES_DB=infrared_vision
POSTGRES_USER=infrared
POSTGRES_PASSWORD=infrared
POSTGRES_PORT=5432
DB_URL=postgresql://infrared:infrared@postgres:5432/infrared_vision

# Gateway networking
CORS_ALLOW_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
NGINX_PORT=8080
REDIS_PORT=6379
