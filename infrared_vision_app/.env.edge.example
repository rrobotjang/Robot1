# Edge deployment
APP_NAME=Infrared Vision Edge
APP_VERSION=0.2.0
APP_RELEASE_CHANNEL=edge

# Edge-local auth and inference
AUTH_SECRET=change-me-if-device-is-shared
AUTH_EXPIRES_MINUTES=30
AUTH_REFRESH_EXPIRES_DAYS=7
IAM_MODE=local
CV_SERVICE_MODE=local
CV_SERVICE_URL=http://127.0.0.1:8030
CV_SERVICE_TIMEOUT=10.0

# Storage
# Use sqlite for durable local edge logging
DB_BACKEND=sqlite
APP_DB_PATH=/app/data/infrared_vision_edge.db

# Optional ultra-lightweight mode
# DB_BACKEND=memory

# Queue
QUEUE_BACKEND=memory
QUEUE_URL=redis://redis:6379/0
QUEUE_NAME=infrared:edge:queue
QUEUE_RESULT_TTL_SECONDS=1800

# Vector search
VECTOR_DB_BACKEND=memory

# UI / networking
CORS_ALLOW_ORIGINS=http://127.0.0.1:8010,http://localhost:8010
AUTO_REFRESH_SECONDS=10
EDGE_PORT=8010
